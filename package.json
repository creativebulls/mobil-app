  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:emulator": "EXPO_PUBLIC_API_URL=http://10.0.2.2:4000 expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:dev": "eas build --platform android --profile development",
    "build:android:apk:local": "bash scripts/build-android-apk-local.sh",
    "build:android:aab:local": "bash scripts/build-android-aab-local.sh",
    "build:ios:ipa:local": "bash scripts/build-ios-ipa-local.sh",
    "build:ios:simulator:local": "bash scripts/build-ios-simulator-local.sh",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "backend:dev": "npm --prefix backend run dev",
    "backend:install": "npm --prefix backend install"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "ios": {
        "buildFromSource": [
          ".*"
        ]
      }
    }
  }
