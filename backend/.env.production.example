# ---------------------------------------------------------------------------
# PRODUCTION configuration
# Copy to `.env.production` (gitignored) and fill in real secrets.
# Loaded automatically when NODE_ENV=production.
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=4000

# Point at the production MongoDB instance.
MONGODB_URI=mongodb://127.0.0.1:27017/whereabout

# Generate strong unique secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-openssl-rand-hex-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=365d

# Public production API base URL (server IP / domain), as seen by clients.
# When fronted by the Nginx reverse proxy this has NO port (served on 80/443).
APP_URL=https://mobilevps.tech
MOBILE_DEEP_LINK_SCHEME=mobileapp
# Lock CORS down to your real client origins in production.
CORS_ORIGIN=*

# Real SMTP provider for production emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WhereAbout <noreply@whereabout.app>"

UPLOAD_DIR=uploads
MINIMUM_ACCOUNT_AGE=16

# Firebase Cloud Messaging (push notifications). Provide ONE of these:
#   - Path to the service-account JSON stored on the server (recommended):
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/whereabout/firebase-service-account.json
#   - Or the service-account JSON inline (raw JSON or base64-encoded). Leave PATH empty if you use this:
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Voice calling (WebRTC). STUN is public/free; TURN is needed for reliable
# connections on cellular/mobile networks (run coturn on the VPS).
STUN_URLS=stun:stun.l.google.com:19302
# TURN_URLS=turn:turn.mobilevps.tech:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=

PLACES_PROVIDER=foursquare
FOURSQUARE_API_KEY=
FOURSQUARE_API_VERSION=2025-06-17
# Photos & ratings are billed "Pro" fields; keep 'false' on the free tier.
FOURSQUARE_ENABLE_PRO_FIELDS=false
OPENTRIPMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
PLACES_DEFAULT_LAT=28.6139
PLACES_DEFAULT_LON=77.2090
PLACES_USER_AGENT="WhereAboutApp/1.0 (support@whereabout.app)"
