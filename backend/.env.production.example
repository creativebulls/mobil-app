# ---------------------------------------------------------------------------
# PRODUCTION configuration
# Copy to `.env.production` (gitignored) and fill in real secrets.
# Loaded automatically when NODE_ENV=production.
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=4000

# Point at the production MongoDB instance.
MONGODB_URI=mongodb://127.0.0.1:27017/whereabout

# Generate strong unique secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-openssl-rand-hex-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=365d

# Public production API base URL (server IP / domain).
APP_URL=http://187.127.180.2:4000
MOBILE_DEEP_LINK_SCHEME=mobileapp
# Lock CORS down to your real client origins in production.
CORS_ORIGIN=*

# Real SMTP provider for production emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WhereAbout <noreply@whereabout.app>"

UPLOAD_DIR=uploads
MINIMUM_ACCOUNT_AGE=16

PLACES_PROVIDER=opentripmap
OPENTRIPMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
PLACES_DEFAULT_LAT=28.6139
PLACES_DEFAULT_LON=77.2090
PLACES_USER_AGENT="WhereAboutApp/1.0 (support@whereabout.app)"
