NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://localhost:27018/whereabout

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
# Long-lived refresh token (rotated on each use) so users stay signed in
# until they log out or clear the app cache.
JWT_REFRESH_EXPIRES_IN=365d

APP_URL=http://localhost:4000
MOBILE_DEEP_LINK_SCHEME=mobileapp
CORS_ORIGIN=*

# Email — Mailpit for local testing (included in docker compose)
# Web inbox: http://localhost:8025
# Leave SMTP_HOST empty to log emails to the console instead
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WhereAbout <noreply@whereabout.app>"

UPLOAD_DIR=uploads
MINIMUM_ACCOUNT_AGE=16

# Places provider (swappable): opentripmap | sample | google
# - opentripmap: real places + photos (needs a free key from opentripmap.io)
# - sample: curated offline data (used automatically if no key is set)
# - google: reserved for a future Google Places implementation
PLACES_PROVIDER=opentripmap
OPENTRIPMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
# Fallback location for "top rated" places when the user has no location (New Delhi)
PLACES_DEFAULT_LAT=28.6139
PLACES_DEFAULT_LON=77.2090
# Required by Nominatim usage policy — identify your app
PLACES_USER_AGENT="WhereAboutApp/1.0 (support@whereabout.app)"

# Admin panel — http://localhost:4000/admin/
ADMIN_EMAIL=admin@whereabout.app
ADMIN_PASSWORD=admin-change-me

# --- WebRTC voice/group calling -------------------------------------------
# STUN is free and helps peers discover their public address. It is NOT enough
# on its own: on mobile/cellular networks (carrier-grade NAT) calls will fail
# to connect without a TURN relay. Configure TURN below for reliable calls.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302
#
# TURN relay (STRONGLY recommended). Run coturn on your VPS, e.g. on mobilevps.tech:
#   sudo apt-get install coturn
#   # /etc/turnserver.conf:
#   #   listening-port=3478
#   #   tls-listening-port=5349
#   #   fingerprint
#   #   lt-cred-mech
#   #   realm=mobilevps.tech
#   #   user=whereabout:SOME_STRONG_SECRET
#   #   external-ip=<your_server_public_ip>
#   #   min-port=49152
#   #   max-port=65535
#   sudo systemctl enable --now coturn
# Then set (comma-separate UDP/TCP/TLS variants for best reachability):
# TURN_URLS=turn:mobilevps.tech:3478?transport=udp,turn:mobilevps.tech:3478?transport=tcp,turns:mobilevps.tech:5349?transport=tcp
# TURN_USERNAME=whereabout
# TURN_CREDENTIAL=SOME_STRONG_SECRET
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
