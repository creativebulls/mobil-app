# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/

# Environment & secrets (keep *.example templates in git)
.env
.env.*
!.env.example
!.env*.example

# Firebase config & service-account keys (never commit secrets)
google-services.json
**/google-services.json
*firebase-adminsdk*.json
serviceAccountKey*.json

# User uploads (profile photos, post images, etc.)
uploads/
**/uploads/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by prebuild)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# Metro
.metro-health-check*

# Build output
build/
*.tsbuildinfo

# Logs & debug
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*

# Testing & coverage
coverage/

# macOS
.DS_Store
*.pem

# Editors / IDE (local settings only)
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Temporary files
tmp/
temp/
.cache/
