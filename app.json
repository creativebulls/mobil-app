{
  "expo": {
    "name": "CRAVE",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "mobileapp",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CRAVE uses your location to show awesome places near you.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.mohit9313.mobileapp",
      "buildNumber": "6",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mobileapp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBMessaging"]
          }
        }
      ],
      "expo-router",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app-icons/crave-black.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/app-icons/crave-full.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "./plugins/withWhereaboutNetworkSecurity",
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#52BAD7"
              },
              "colorControlActivated": {
                "light": "#52BAD7"
              },
              "colorControlHighlight": {
                "light": "#3352BAD7"
              },
              "textColorPrimary": {
                "light": "#2D1A35"
              },
              "textColorSecondary": {
                "light": "#9CA3AF"
              },
              "windowBackground": {
                "light": "#FFFFFF"
              }
            }
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CRAVE to access your photos to set a profile picture.",
          "cameraPermission": "Allow CRAVE to use the camera for your profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow CRAVE to use your location to show places near you."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#52BAD7",
          "sounds": ["./assets/notification_recived_sount.mp3"]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CRAVE to use the camera to scan a friend's connect code."
        }
      ],
      "expo-audio",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93bea249-5bca-463f-861e-4f8d6e4aa7a5"
      }
    },
    "owner": "mohit9313"
  }
}
