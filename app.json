{
  "expo": {
    "name": "mobile-app",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "mobileapp",
    "splash": {
      "image": "./assets/splash-screen-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#9447B3"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WhereAbout uses your location to show awesome places near you.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.anonymous.mobileapp"
    },
    "android": {
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#9447B3",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mobileapp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-status-bar",
      "expo-splash-screen",
      "./plugins/withWhereaboutNetworkSecurity",
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#F36464"
              },
              "colorControlActivated": {
                "light": "#F36464"
              },
              "colorControlHighlight": {
                "light": "#33F36464"
              },
              "textColorPrimary": {
                "light": "#2D1A35"
              },
              "textColorSecondary": {
                "light": "#9CA3AF"
              },
              "windowBackground": {
                "light": "#FFFFFF"
              }
            }
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WhereAbout to access your photos to set a profile picture.",
          "cameraPermission": "Allow WhereAbout to use the camera for your profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow WhereAbout to use your location to show places near you."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F36464"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow WhereAbout to use the camera to scan a friend's connect code."
        }
      ],
      "expo-audio",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93bea249-5bca-463f-861e-4f8d6e4aa7a5"
      }
    },
    "owner": "mohit9313"
  }
}
