# ---------------------------------------------------------------------------
# Mobile app → backend URL (baked in at build/start time)
# ---------------------------------------------------------------------------

# Android emulator (host machine from emulator's network):
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# iOS simulator / web on same machine:
# EXPO_PUBLIC_API_URL=http://localhost:4000

# Physical device on same Wi‑Fi (replace with your computer's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.31.130:4000
# Find IP: ipconfig getifaddr en0

# Production:
# EXPO_PUBLIC_API_URL=https://mobilevps.tech

# Backend dev server (run separately):
#   npm run backend:dev
# Health check: http://10.0.2.2:4000/health
# API base:     http://10.0.2.2:4000/api/v1

# iOS IPA signing (optional):
# DEVELOPMENT_TEAM=XXXXXXXXXX
# IOS_EXPORT_METHOD=development
